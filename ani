            font-size: 1.2rem;
            margin-bottom: 40px;
            font-weight: 600;
            letter-spacing: 1px;
            text-align: center;
        }

        /* 3D Grid Layout */
        .arcade-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            max-width: 1400px;
            width: 100%;
            padding: 10px;
        }

        /* Premium 3D Neumorphic Glass Card */
        .game-card {
            background: rgba(255, 255, 255, 0.75);
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 24px;
            padding: 20px;
            box-shadow: 10px 10px 20px #cbd5e1, -10px -10px 20px #ffffff;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
            height: 190px;
        }

        /* 3D Pop Effect on Hover */
        .game-card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 15px 20px 30px rgba(67, 100, 247, 0.15), -10px -10px 25px #ffffff;
            border-color: #4364f7;
        }

        .card-icon {
            font-size: 2.2rem;
            margin-bottom: 10px;
            filter: drop-shadow(0px 4px 8px rgba(0,0,0,0.1));
        }

        .game-title {
            font-size: 1.3rem;
            font-weight: 700;
            color: #1e293b;
        }

        .game-desc {
            color: #64748b;
            font-size: 0.9rem;
            margin: 8px 0 15px 0;
            line-height: 1.4;
        }

        /* Responsive Cool 3D Play Button */
        .play-btn {
            background: linear-gradient(135deg, #4364f7 0%, #6fb1fc 100%);
            color: #ffffff;
            border: none;
            padding: 12px;
            border-radius: 16px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            width: 100%;
            text-align: center;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(67, 100, 247, 0.3);
            box-sizing: border-box;
        }

        .play-btn:hover {
            background: linear-gradient(135deg, #0052d4 0%, #4364f7 100%);
            box-shadow: 0 6px 20px rgba(0, 82, 212, 0.5);
            transform: translateY(-2px);
        }

        footer {
