        h1 {
            font-size: 3rem;
            margin: 30px 0 5px 0;
            text-transform: uppercase;
            letter-spacing: 2px;
            background: linear-gradient(45deg, #0052d4, #4364f7, #6fb1fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0px 4px 10px rgba(67, 100, 247, 0.2));
            text-align: center;
        }

        .subtitle {
